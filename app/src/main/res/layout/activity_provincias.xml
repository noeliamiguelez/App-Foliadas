<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF1D1"
    tools:context=".UI.LogIn">

    <Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#A30000">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="PROVINCIAS"
            android:textColor="@color/white"
            android:fontFamily="@font/jeju_hallasan"
            android:textSize="40dp"
            android:gravity="center" />
    </Toolbar>

    <EditText
        android:id="@+id/buscar"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/toolbar"
        android:background="@drawable/edittext_bg"
        android:layout_marginTop="80dp"
        android:layout_centerHorizontal="true"

        android:hint="Buscar"
        android:fontFamily="@font/jeju_hallasan"
        android:inputType="text"/>

    <ListView
        android:id="@+id/lista_provincias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginHorizontal="15dp"
        android:layout_below="@+id/buscar"
        android:layout_marginTop="20dp"
        android:background="@drawable/provincias_bg"
        android:divider="#FFF1D1"
        android:dividerHeight="10dp"/>


</RelativeLayout>